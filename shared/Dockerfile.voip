FROM alpine:3.21

RUN apk add --no-cache asterisk asterisk-sample-config asterisk-sounds-en

# Copy config (bizim config'lerimiz sample'ların üzerine yazılır)
COPY voip/pjsip.conf /etc/asterisk/pjsip.conf
COPY voip/extensions.conf /etc/asterisk/extensions.conf
COPY voip/rtp.conf /etc/asterisk/rtp.conf
COPY voip/modules.conf /etc/asterisk/modules.conf

RUN mkdir -p /run/asterisk

EXPOSE 5060/udp 10000-20000/udp

CMD ["asterisk", "-f", "-vvv"]
