# Shark-Tank Lab Credentials
# Bu dosya tüm login bilgilerini içerir.
# Docker Compose, generate-traffic.sh ve rehberler bu dosyadan okur.

# FTP Server (172.50.2.15:21)
FTP_USER=ftpuser
FTP_PASS=ftppass123

# HTTP Auth - Admin (POST /auth)
HTTP_ADMIN_USER=admin
HTTP_ADMIN_PASS=secret123

# HTTP Auth - Guest (POST /auth, hatalı giriş)
HTTP_GUEST_USER=guest
HTTP_GUEST_PASS=wrong

# HTTP Auth - Employee (Forensics senaryosu)
HTTP_EMPLOYEE_USER=employee
HTTP_EMPLOYEE_PASS=companySecret2024

# FTP - Hatalı giriş (forensics senaryosu)
FTP_WRONG_PASS=wrongpassword

# Email / IMAP - kullanici (POP3 110, IMAP 143, Submission 587)
IMAP_USER=kullanici
IMAP_PASS=secret123

# SIP Extension 1000 (VoIP)
SIP_USER_1000=1000
SIP_PASS_1000=voip123

# SIP Extension 1001 (VoIP)
SIP_USER_1001=1001
SIP_PASS_1001=voip456
